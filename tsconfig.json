{
  "compilerOptions": {
    "module": "esnext",
    "rootDir": "./src",
    "outDir": "./dist",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src",
    "src/app/seedAdmin"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
